RCMR2 INT3 VN 100MEG
G_CM VREF CM1 VALUE={V(INT3, VREF)* {KGCM} }
R_CM CM1 CM2 {RCM}
L_CM CM2 VREF {LCM}
RAAA VREF CM1 1E12
CAAA VREF CM1 1P
RAAAA CM1 CM2 1E12
CAAAA CM1 CM2 1P
RAAAAA CM2 VREF 1E12
CAAAAA CM2 VREF 1P
EPSRR VP3 VP2 VALUE={0}
ECMRR VP2 VP1 VALUE={V(CM1,VREF)}
EOS VP1 VP VALUE={{VOFFSET}}
RIN VP3 VN 10MEG
RA VREF VGAIN 1E12
GGAIN VREF VGAIN VALUE={V(VP3,VN)*{AOL}/200}
RP1 VGAIN VREF 1K
CP1 VGAIN VREF 150N
EBUFFER INT2 VREF VALUE={V(VGAIN,VREF)}
ROUT INT2 OUT 0.1
E_UP SUPPLY_P UP VALUE={TABLE(V(SUPPLY_P,GND),0,0,0.05,0.001)}
E_DW DW SUPPLY_N VALUE={TABLE(V(SUPPLY_P,GND),0,0,0.05,0.001)}
G_LIMIT_UP VGAIN UP VALUE={V(VGAIN,UP)/1M*IF(V(VGAIN,UP) > 0,1,0)}
G_LIMIT_DW DW VGAIN VALUE={V(DW,VGAIN)/1M*IF(V(VGAIN,DW) < 0, 1, 0)}
.ENDS ONE_EDI3035AS_OPAMP1
.SUBCKT ONE_EDI3035AS_COUNTER_REGISTER_JUMP_2 JUMP1 JUMP2 JUMP3 RESET CLK IN STOREDB
E100 TIME_ON 0 VALUE={5N}
X0001 CLK CLK_DEL TIME_ON ONE_EDI3035AS_TIMING_FILTER_ON
ECTRL CTRL 0 VALUE={IF(V(CLK_DEL) > 0.5 & V(RESET)<0.5,1,0)}
G1 IN STORED VALUE={V(IN,STORED)/1M*IF(V(CTRL) > 0.5,1,0)}
EF1 JUMP1_VAL 0 VALUE={1}
EF2 JUMP2_VAL 0 VALUE={3}
EF3 JUMP3_VAL 0 VALUE={4}
GF1 JUMP1_VAL STORED VALUE={V(JUMP1_VAL, STORED )/2M* V(JUMP1)}
GF2 JUMP2_VAL STORED VALUE={V(JUMP2_VAL, STORED )/2M* V(JUMP2)}
GF3 JUMP3_VAL STORED VALUE={V(JUMP3_VAL, STORED )/2M* V(JUMP3)}
C1 STORED GH 1U
RN GH 0 1M
R1 STORED 0 1E8
G2 STORED 0 VALUE={V(STORED)/2M* V(RESET)}
E1 STOREDA 0 VALUE={IF(V(STORED)-FLOOR(V(STORED)) > FLOOR(V(STORED))+1-V(STORED), FLOOR(V(STORED))+1, FLOOR(V(STORED)))}
RV STOREDA STOREDB 1
CV STOREDB 0 1N
.ENDS ONE_EDI3035AS_COUNTER_REGISTER_JUMP_2
.SUBCKT ONE_EDI3035AS_ADV_FILTER_TIME_2 IN OUT PARAMS: TIME_SET=1N
R1 IN 0 1E9
R2 OUT 0 1E9
G_RISE IN IN_DEL VALUE={V(IN,IN_DEL)/ MAX(({TIME_SET}/ABS(LOG(0.001))/1E-9),0.1)}
C_RISE IN_DEL 0 1N
R_3 IN_DEL 0 1E12
X_CMP IN_DEL OUT 0 ONE_EDI3035AS_STP_IDEAL PARAMS: P_TH_UP=0.999 P_TH_DW=0.001
.ENDS ONE_EDI3035AS_ADV_FILTER_TIME_2
.SUBCKT ONE_EDI3035AS_STP_IDEAL1 IN OUT GND UP DW
E_OUTP1 OUTP 0 VALUE={IF( V(IN,GND)>=V(UP) | V(OUTN)<0.5 , 1,0 )}
E_OUTN1 OUTN 0 VALUE={IF( V(IN,GND)<=V(DW)| V(OUTP)<0.5 , 1,0 )}
E_OUT OUT 0 VALUE={V(OUTP)}
R1 IN 0 1E9
R2 OUT 0 1E9
.ENDS ONE_EDI3035AS_STP_IDEAL1
.SUBCKT ONE_EDI3035AS_STP_IDEAL IN OUT GND PARAMS: P_TH_UP=0.9 P_TH_DW=0.1
E_OUTP1 OUTP 0 VALUE={IF( V(IN,GND)>={P_TH_UP} | V(OUTN)<0.25 , 1,0 )}
E_OUTN1 OUTN 0 VALUE={IF( V(IN,GND)<={P_TH_DW} | V(OUTP)<0.5 , 1,0 )}
E_OUT OUT 0 VALUE={V(OUTP)}
R1 IN 0 1E9
R2 OUT 0 1E9
.ENDS ONE_EDI3035AS_STP_IDEAL
.SUBCKT ONE_EDI3035AS_STN_IDEAL IN OUT GND PARAMS: P_TH_UP=0.9 P_TH_DW=0.1
E_OUTP1 OUTP 0 VALUE={IF( V(IN,GND)>={P_TH_UP} | V(OUTN)<0.5 , 1,0 )}
E_OUTN1 OUTN 0 VALUE={IF( V(IN,GND)<={P_TH_DW} | V(OUTP)<0.5 , 1,0 )}
E_OUT OUT 0 VALUE={V(OUTN)}
R1 IN 0 1E9
R2 OUT 0 1E9
.ENDS ONE_EDI3035AS_STN_IDEAL
.SUBCKT ONE_EDI3035AS_CL_DIO C A PARAMS: P_V_BV=5 P_I_BV=1
G_CL_DIO C A VALUE {TABLE(V(C,A) , 0,0 , {P_V_BV}*1,0 , {P_V_BV}*1.02,{P_I_BV} , 10*{P_V_BV}, 100*{P_I_BV} )}
C_CL_DIO C A 10F
R_CL_DIO C A 1E12
.ENDS ONE_EDI3035AS_CL_DIO
.SUBCKT ONE_EDI3035AS_ESD_DIO A C PARAMS: P_V_BV=5 P_I_BV=1
G_ESD_DIO A C VALUE {TABLE(V(A,C) , 0,0 , {P_V_BV}*1.01,0 , {P_V_BV}*1.02,{P_I_BV} , 10*{P_V_BV}, 100*{P_I_BV} )}
C_ESD_DIO A C 10F
R_ESD_DIO A C 1E12
.ENDS ONE_EDI3035AS_ESD_DIO
.SUBCKT ONE_EDI3035AS_RC_DELAY_10_ADVANCED IN OUT TIME_SET_ON TIME_SET_OFF
E1 TIME_SET_5_ON 0 VALUE={V(TIME_SET_ON)/2}
E2 TIME_SET_5_OFF 0 VALUE={V(TIME_SET_OFF)/2}
X_D1 IN D1 TIME_SET_5_ON TIME_SET_5_OFF ONE_EDI3035AS_RC_DELAY_5_ADVANCED
X_D2 D1 OUT TIME_SET_5_ON TIME_SET_5_OFF ONE_EDI3035AS_RC_DELAY_5_ADVANCED
.ENDS ONE_EDI3035AS_RC_DELAY_10_ADVANCED
.SUBCKT ONE_EDI3035AS_RC_DELAY_5_ADVANCED IN OUT TIME_SET_ON TIME_SET_OFF
E1 TIME_SET_BASE_ON 0 VALUE={V(TIME_SET_ON)/5}
E2 TIME_SET_BASE_OFF 0 VALUE={V(TIME_SET_OFF)/5}
X_D1 IN D1 TIME_SET_BASE_ON TIME_SET_BASE_OFF ONE_EDI3035AS_RC_DELAY_BASE_ADVANCED
X_D2 D1 D2 TIME_SET_BASE_ON TIME_SET_BASE_OFF ONE_EDI3035AS_RC_DELAY_BASE_ADVANCED
X_D3 D2 D3 TIME_SET_BASE_ON TIME_SET_BASE_OFF ONE_EDI3035AS_RC_DELAY_BASE_ADVANCED
X_D4 D3 D4 TIME_SET_BASE_ON TIME_SET_BASE_OFF ONE_EDI3035AS_RC_DELAY_BASE_ADVANCED
X_D5 D4 OUT TIME_SET_BASE_ON TIME_SET_BASE_OFF ONE_EDI3035AS_RC_DELAY_BASE_ADVANCED
.ENDS ONE_EDI3035AS_RC_DELAY_5_ADVANCED
.SUBCKT ONE_EDI3035AS_RC_DELAY_BASE_ADVANCED IN OUT TIME_SET_ON TIME_SET_OFF
GDELAY_ON IN IN_DEL VALUE={V(IN,IN_DEL)/MAX((V(TIME_SET_ON)/ABS(LOG(0.5))/1E-9),0.1)*IF(V(IN) > 0.5,1,0)}
GDELAY_OFF IN IN_DEL VALUE={V(IN,IN_DEL)/MAX((V(TIME_SET_OFF)/ABS(LOG(0.5))/1E-9),0.1)*IF(V(IN) < 0.5,1,0)}
C_DELAY IN_DEL 0 1N
RCONV IN_DEL 0 1E12
E_DELAY OUT 0 VALUE={IF( V(IN_DEL) > 0.5 , 1.0,0.0 )}
R1 IN 0 1E9
R2 OUT 0 1E9
.ENDS ONE_EDI3035AS_RC_DELAY_BASE_ADVANCED
.SUBCKT ONE_EDI3035AS_COUNTER_REGISTER RESET CLK IN STORED
X1 CLK CLK_DEL ONE_EDI3035AS_ADV_FILTER_TIME_2 PARAMS: TIME_SET=2N
ECTRL CTRL 0 VALUE={IF(V(CLK_DEL) > 0.999 & V(RESET)<0.001,1,0)}
S1 IN STORED CTRL 0 ONE_EDI3035AS_SW
C1 STORED 0 1U
R1 STORED 0 1E7
S2 STORED 0 RESET 0 ONE_EDI3035AS_SW
.MODEL ONE_EDI3035AS_SW VSWITCH (VON=0.9 VOFF=0.1 RON=1M ROFF=1000MEG)
.ENDS ONE_EDI3035AS_COUNTER_REGISTER
.SUBCKT ONE_EDI3035AS_UP_COUNTER CLK RESET OUT
X1 CLK CLK_DEL ONE_EDI3035AS_ADV_FILTER_TIME_2 PARAMS: TIME_SET=25N
X2 CLK_DEL CLK_DEL_DEL ONE_EDI3035AS_ADV_FILTER_TIME_2 PARAMS: TIME_SET=15N
X3 CLK_DEL_DEL CLK_DEL_DEL_DEL ONE_EDI3035AS_ADV_FILTER_TIME_2 PARAMS: TIME_SET=25N
EAUX AUX OUT2 VALUE={0.1}
EIIN1 IN1 0 VALUE={FLOOR(V(AUX))+1}
E1 CLK1 0 VALUE={IF(V(CLK) > 0.5 & V(CLK_DEL)<0.5,1,0)}
E2 CLK2 0 VALUE={IF(V(CLK_DEL_DEL) > 0.5 & V(CLK_DEL_DEL_DEL)<0.5,1,0)}
EO2 OUT2 0 VALUE={V(OUT1)}
EIN2 IN2 0 VALUE={V(OUT)}
ERESET1 RESET1 0 VALUE={IF(TIME<1N,1,V(RESET))}
XREGISTER1 RESET1 CLK1 IN1 OUT ONE_EDI3035AS_COUNTER_REGISTER
XREGISTER2 RESET1 CLK2 IN2 OUT1 ONE_EDI3035AS_COUNTER_REGISTER
.ENDS ONE_EDI3035AS_UP_COUNTER
.SUBCKT ONE_EDI3035AS_CLOCK_GENERATOR VCLOCK COM FREQUENCY DUTY_CYCLE CLRB PARAMS: C1=1U
E1 I1 0 VALUE={100*{C1} * V(FREQUENCY)/ (1-V(DUTY_CYCLE))}
E2 I2 0 VALUE={100*{C1} * V(FREQUENCY) / V(DUTY_CYCLE)}
G_UP 0 DC VALUE={(1-V(VCLOCKA))*V(I1)*IF(TIME<1N,0,1)*TABLE( (100-V(DC)),0,0,50M,1)* V(CLRB)}
G_DW DC 0 VALUE={V(I2)*IF(TIME<1N,0,1)*TABLE(V(DC),0,0,50M,1)*IF(V(CLRB) <0.5,1,V(VCLOCKA) )}
R1 DC 0 1E12
C_DC DC 0 {C1}
EON ONE 0 VALUE={100}
GX DC ONE VALUE={V(DC,ONE)/5M*IF((V(CLRB)>0.5 & V(CLRB_DEL)<0.5) | (V(VCLOCK)>0.5 & V(VCLOCK_DEL)<0.5),1,0)}
X2 CLOCK1 VCLOCKA ONE_EDI3035AS_ADV_FILTER_TIME_2 PARAMS: TIME_SET=20N
X2A CLRB CLRB_DEL ONE_EDI3035AS_ADV_FILTER_TIME_2 PARAMS: TIME_SET=50N
X3 DC CLOCK1 0 ONE_EDI3035AS_STP_IDEAL PARAMS: P_TH_UP=99.999 P_TH_DW=0.001
ECLOCK VCLOCK COM VALUE={V(VCLOCKA)}
XA VCLOCK VCLOCK_DEL ONE_EDI3035AS_ADV_FILTER_TIME_2 PARAMS: TIME_SET=30N
GY DC 0 VALUE={V(DC,0)/5M*IF(V(VCLOCK)<0.5 & V(VCLOCK_DEL)>0.5,1,0)}
.ENDS ONE_EDI3035AS_CLOCK_GENERATOR