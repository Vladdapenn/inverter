X1 STP_ERROR_SET STP_ERROR_SET_DEL KEEP_STATE_TIME_LIMIT ONE_EDI3035AS_TIMING_FILTER_ON
E2 STP_ERROR_RST 0 VALUE={IF(V(STP_KEEP_ERROR_DIG_RDY_CTRL_DEL) >0.5 & V(STP_ERROR_SET) <0.5 ,1,0)}
X2 STP_ERROR_RST STP_ERROR_RST_DEL ONE_EDI3035AS_ADV_FILTER_TIME_2 PARAMS: TIME_SET=50N
