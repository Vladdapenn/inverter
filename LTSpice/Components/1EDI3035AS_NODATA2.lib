.SUBCKT ONE_EDI3035AS_CURRENT_CONSUMPTION VCC1 GND1 VCC2 GND2 VEE2 CURRENT_STATE NORMAL_CONTROL_ON NORMAL_CONTROL_OFF TON_COMMAND 
+ TOFF_COMMAND
GIQVCC1 VCC1 GND1 VALUE={TABLE(V(VCC1,GND1),0,0,5,5M)* IF(V(CURRENT_STATE)>0.5 & V(CURRENT_STATE) <1.5,1,0)}
GIOPVCC1_ON VCC1 GND1 VALUE={TABLE(V(VCC1,GND1),0,0,5,10M)* IF(V(CURRENT_STATE)>1.5 & V(CURRENT_STATE) <2.5 & V(NORMAL_CONTROL_ON) 
+ >0.5,1,0)}
GIOPVCC1_OFF VCC1 GND1 VALUE={TABLE(V(VCC1,GND1),0,0,5,5.5M)* IF(V(CURRENT_STATE)>1.5 & V(CURRENT_STATE) <2.5 & V(
+ NORMAL_CONTROL_OFF) >0.5,1,0)}
GIOPVCC2_ON2 VCC2 GND2 VALUE={TABLE(V(VCC2,GND2),0,0,15,10.3M)* IF(V(CURRENT_STATE)>1.5 & V(CURRENT_STATE) <2.5 & V(
+ NORMAL_CONTROL_ON) >0.5,1,0)}
GIOPVCC2_OFF2 VCC2 GND2 VALUE={TABLE(V(VCC2,GND2),0,0,15,10.3M)* IF(V(CURRENT_STATE)>1.5 & V(CURRENT_STATE) <2.5 & V(
+ NORMAL_CONTROL_OFF) >0.5,1,0)}
GIOPVEE2_ON2 VEE2 GND2 VALUE={TABLE(V(VEE2,GND2),-5,-1.5M,0,0)* IF(V(CURRENT_STATE)>1.5 & V(CURRENT_STATE) <2.5 & V(
+ NORMAL_CONTROL_ON) >0.5,1,0)}
GIOPVEE2_OFF2 VEE2 GND2 VALUE={TABLE(V(VEE2,GND2),-5,-1.5M,0,0)* IF(V(CURRENT_STATE)>1.5 & V(CURRENT_STATE) <2.5 & V(
+ NORMAL_CONTROL_OFF) >0.5,1,0)}
.ENDS ONE_EDI3035AS_CURRENT_CONSUMPTION
.SUBCKT ONE_EDI3035AS_RDY_NFLT_BLOCK RDY NFLT GND1 UVLO1_ERROR_DIG_RDY_CTRL STP_KEEP_ERROR_DIG_RDY_CTRL UVLO2_ERROR_DIG_RDY_CTRL 
+ OVLO2_ERROR_DIG_RDY_CTRL UVLO3_ERROR_DIG_RDY_CTRL OVLO3_ERROR_DIG_RDY_CTRL OCP_ERROR_DIG_NFLT_CTRL GM_ERROR_DIG_RDY_CTRL 
+ OSM_ERROR_DIG_RDY_CTRL CURRENT_STATE RDY_CTRL NFLT_CTRL VCC1 VCC1_STARTUP_COMPLETE
E1 CLR2NFLTH 0 VALUE={50N}
E2 CLR2RDYH 0 VALUE={50N}
E3 RDY_CTRL_SET 0 VALUE={IF(V(UVLO1_ERROR_DIG_RDY_CTRL) > 0.5 | V(STP_KEEP_ERROR_DIG_RDY_CTRL) > 0.5 | V(UVLO2_ERROR_DIG_RDY_CTRL) 
+ > 0.5 | V(OVLO2_ERROR_DIG_RDY_CTRL) > 0.5 | V(UVLO3_ERROR_DIG_RDY_CTRL) > 0.5 | V(OVLO3_ERROR_DIG_RDY_CTRL)>0.5 | V(
+ GM_ERROR_DIG_RDY_CTRL) > 0.5 | V(OSM_ERROR_DIG_RDY_CTRL) > 0.5,1,0)}
E4 NFLT_CTRL_SET 0 VALUE={IF(V(OCP_ERROR_DIG_NFLT_CTRL) > 0.5,1,0)}
E5 RDY_RESET 0 VALUE={IF(V(CURRENT_STATE) > 1.5,1,0)}
E5A NFLT_RESET 0 VALUE={IF(V(CURRENT_STATE) > 1.5 | V(CURRENT_STATE) < 0.5,1,0)}
X1A RDY_RESET RDY_RESET_DEL CLR2RDYH ONE_EDI3035AS_TIMING_FILTER_ON
X1B NFLT_RESET NFLT_RESET_DEL CLR2RDYH ONE_EDI3035AS_TIMING_FILTER_ON
X2 RDY_CTRL_SET RDY_RESET_DEL RDY_CTRL RDY_CTRLN ONE_EDI3035AS_RS_LATCH
X3 NFLT_CTRL_SET NFLT_RESET_DEL NFLT_CTRL NFLT_CTRLN ONE_EDI3035AS_RS_LATCH
ERDY_RES RDY_RES 0 VALUE={100}
GRDY RDY GND1 VALUE={V(RDY,GND1)/V(RDY_RES) * IF (V(RDY_CTRL) > 0.5 & V(CURRENT_STATE) > 0.5,1,0)}
GNFLT NFLT GND1 VALUE={V(NFLT,GND1)/50 * V(NFLT_CTRL)}
R1 RDY GND1 1E12
R2 NFLT GND1 1E12
